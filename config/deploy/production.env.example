POSTGRES_PASSWORD=replace-with-a-long-url-safe-password
RAILS_MASTER_KEY=replace-with-config-master-key
OPENAI_API_KEY=replace-with-openai-api-key

ANTHROPIC_API_KEY=
FORCE_SSL=false
ASSUME_SSL=false
RUN_SEED_VERIFICATIONS=false
RAILS_MAX_THREADS=3
JOB_THREADS=1
JOB_CONCURRENCY=1
VERIFY_CONCURRENCY=1
SOLID_QUEUE_IN_PUMA=true
EXTRACTION_PROVIDER=openai
EXTRACTION_MODEL=gpt-5.4-nano
EXTRACTION_EFFORT=low
EXTRACTION_OCR_ENGINE=tesseract
EXTRACTION_OCR_REGION_REFINEMENT=false
EXTRACTION_OCR_TIMEOUT_SECONDS=8
