<div class="h-full flex flex-col"
     data-controller="review-mode"
     data-review-mode-initial-value="<%= (@payload || {}).to_json %>"
     data-review-mode-next-url-value="<%= reviewer_review_next_path %>"
     data-review-mode-exit-url-value="<%= reviewer_queue_path %>">

  <%# Quiet top bar: the only persistent chrome in review mode. %>
  <header class="flex items-center justify-between gap-6 px-6 py-3 border-b border-line text-sm text-ink-muted">
    <%= link_to "← Exit review mode", reviewer_queue_path,
          class: "shrink-0 hover:text-ink underline underline-offset-4 decoration-line-strong" %>
    <p class="shrink-0" data-review-mode-target="progress"></p>
    <p class="hidden xl:block text-ink-faint" aria-hidden="true">
      <kbd class="px-1.5 py-0.5 rounded border border-line bg-raised text-ink-muted">A</kbd> approve
      <span class="mx-1">·</span>
      <kbd class="px-1.5 py-0.5 rounded border border-line bg-raised text-ink-muted">R</kbd> reject
      <span class="mx-1">·</span>
      <kbd class="px-1.5 py-0.5 rounded border border-line bg-raised text-ink-muted">B</kbd> better image
      <span class="mx-1">·</span>
      <kbd class="px-1.5 py-0.5 rounded border border-line bg-raised text-ink-muted">Space</kbd> skip
      <span class="mx-1">·</span>
      <kbd class="px-1.5 py-0.5 rounded border border-line bg-raised text-ink-muted">U</kbd> undo
      <span class="mx-1">·</span>
      <kbd class="px-1.5 py-0.5 rounded border border-line bg-raised text-ink-muted">Esc</kbd> exit
    </p>
  </header>

  <%# Live announcements and the findings mirror for screen readers. %>
  <div class="sr-only" aria-live="polite" data-review-mode-target="srStatus"></div>
  <div class="sr-only" data-review-mode-target="srFindings" aria-label="Findings for the current label"></div>

  <%# The workspace: artwork center stage, the evidence inspector at right. %>
  <div class="relative flex-1 min-h-0 flex" data-review-mode-target="workspace">
    <div class="flex-1 min-w-0 flex flex-col transition-opacity duration-150" data-review-mode-target="stage">
      <div class="flex-1 min-h-0 flex flex-col items-center justify-center gap-4 px-8 py-6">
        <div class="text-center" data-review-mode-target="caption"></div>
        <div class="relative max-h-full min-h-0" data-review-mode-target="frame">
          <img class="max-h-[62vh] max-w-full rounded-sm shadow-xl shadow-ink/15 bg-white"
               alt="" data-review-mode-target="image">
          <svg class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true"
               data-review-mode-target="svg"></svg>
        </div>
        <div class="hidden max-w-xl w-full" data-review-mode-target="fallback"></div>
      </div>

      <%# Decision controls under the artwork; the guard line speaks only
          when approving over failures. %>
      <footer class="flex flex-col items-center gap-2.5 px-6 pt-2 pb-6" data-review-mode-target="controls">
        <p class="text-sm min-h-5" aria-live="polite" data-review-mode-target="summary"></p>
        <div class="flex items-center justify-center gap-3">
          <button type="button" data-action="review-mode#approve"
                  class="rounded-lg bg-pass text-on-strong px-9 py-3.5 text-lg font-semibold cursor-pointer
                         transition duration-150 hover:brightness-110 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus">
            ✓ Approve
          </button>
          <button type="button" data-action="review-mode#reject"
                  class="rounded-lg bg-fail text-on-strong px-9 py-3.5 text-lg font-semibold cursor-pointer
                         transition duration-150 hover:brightness-110 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus">
            ✗ Reject
          </button>
        </div>
        <button type="button" data-action="review-mode#requestRetake"
                class="text-sm text-ink-faint px-3 py-1.5 hover:text-ink-muted cursor-pointer underline-offset-4 hover:underline">
          Request a better image
        </button>
      </footer>
    </div>

    <%# The evidence inspector: every check, grouped by severity, absences
        badged inline. One scrollable column; hover a row to spotlight its
        box, click to unfold the regulation-cited comparison. %>
    <aside class="hidden lg:flex flex-col w-[370px] shrink-0 border-l border-line bg-panel min-h-0"
           aria-label="Verification findings" data-review-mode-target="inspector"></aside>

    <%# Queue-clear state. %>
    <div class="hidden h-full w-full flex-col items-center justify-center text-center" data-review-mode-target="empty">
      <p class="text-2xl font-semibold mb-2">Queue clear.</p>
      <p class="text-ink-muted mb-6">Every submitted application has a decision.</p>
      <%= link_to "Back to the queue", reviewer_queue_path,
            class: "rounded-lg bg-ink text-surface px-5 py-2.5 font-medium hover:opacity-90" %>
    </div>
  </div>

  <%# Undo toast. %>
  <div class="hidden fixed bottom-24 left-1/2 -translate-x-1/2 rounded-xl bg-raised border border-line px-5 py-3 shadow-xl shadow-ink/15 flex items-center gap-4"
       data-review-mode-target="toast" role="status">
    <span data-review-mode-target="toastMessage"></span>
    <button type="button" data-action="review-mode#undo"
            class="font-semibold underline underline-offset-4 hover:text-ink cursor-pointer">
      Undo (U)
    </button>
  </div>
</div>
