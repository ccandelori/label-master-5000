<% latest_attempt = application.verification_attempts.order(created_at: :desc).first %>
<tr id="batch_row_<%= application.id %>" class="border-t border-line align-top">
  <td class="px-4 py-3 text-ink-faint"><%= application.row_number %></td>
  <td class="px-4 py-3"><%= application.serial_number %></td>
  <th scope="row" class="px-4 py-3 font-medium"><%= application.brand_name %></th>
  <td class="px-4 py-3 text-ink-muted"><%= application.beverage_type.capitalize %></td>
  <td class="px-4 py-3">
    <% if verification %>
      <%= verdict_chip(verification.overall_verdict) %>
      <% worst = actionable_checks(verification).first %>
      <% if worst&.note %>
        <p class="text-ink-muted mt-1 max-w-md"><%= truncate(worst.note, length: 110) %></p>
      <% end %>
    <% elsif latest_attempt&.queued? %>
      <span class="inline-flex items-center gap-1.5 text-ink-faint">
        <span class="inline-block h-2 w-2 rounded-full bg-warn animate-pulse" aria-hidden="true"></span>
        queued
      </span>
    <% elsif latest_attempt&.processing? %>
      <span class="inline-flex items-center gap-1.5 text-ink-faint">
        <span class="inline-block h-2 w-2 rounded-full bg-warn animate-pulse" aria-hidden="true"></span>
        processing
      </span>
    <% elsif latest_attempt&.error? %>
      <%= verdict_chip("error") %>
    <% else %>
      <span class="inline-flex items-center gap-1.5 text-ink-faint">
        <span class="inline-block h-2 w-2 rounded-full bg-warn animate-pulse" aria-hidden="true"></span>
        waiting
      </span>
    <% end %>
  </td>
  <td class="px-4 py-3 text-ink-faint whitespace-nowrap">
    <%= verification&.latency_ms ? "#{(verification.latency_ms / 1000.0).round(1)}s" : "—" %>
  </td>
  <td class="px-4 py-3 text-right">
    <%= link_to "Open", label_application_path(application), class: "text-ink-muted underline hover:no-underline" %>
  </td>
</tr>
