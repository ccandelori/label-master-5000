<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "LabelMaster 5000" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-surface text-ink text-base">
    <header class="bg-raised border-b border-line">
      <div class="max-w-5xl mx-auto px-5 py-4 flex items-center justify-between">
        <%= link_to root_path, class: "flex items-center gap-2 text-lg font-semibold text-ink" do %>
          <span aria-hidden="true">☑</span> LabelMaster 5000
        <% end %>
        <nav class="flex gap-2 text-base" aria-label="Site areas">
          <%= nav_link "Reviewer", reviewer_queue_path, area: :reviewer %>
          <%= nav_link "Pre-review", new_label_application_path, area: :pre_review %>
          <%= nav_link "Rules reference", rules_path, area: :rules %>
        </nav>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-5 py-8">
      <% if current_area %>
        <p class="mb-4"><%= area_tag(current_area) %></p>
      <% end %>
      <% if notice.present? %>
        <p class="mb-6 rounded-lg bg-focus-tint text-focus px-4 py-3" role="status"><%= notice %></p>
      <% end %>
      <% if alert.present? %>
        <p class="mb-6 rounded-lg bg-fail-tint text-fail px-4 py-3" role="alert"><%= alert %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
