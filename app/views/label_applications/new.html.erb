<h1 class="text-2xl font-semibold mb-2">Pre-check your label before you file</h1>
<p class="text-stone-600 mb-6 max-w-2xl">
  Enter the application details as you would file them, attach the label
  artwork, and get a field-by-field check with the Beverage Alcohol Manual
  rule behind each finding — so you can fix problems before TTB sees them.
  When it is clean, submit it straight to the reviewer queue.
</p>

<%= render "shared/pre_review_mode_nav", active: :single %>

<%= render "form", application: @application %>

<% if @stats %>
  <section class="mt-8 bg-white rounded-xl border border-stone-200 p-5" aria-label="Verification statistics">
    <h2 class="text-base font-semibold mb-3">So far</h2>
    <div class="flex flex-wrap gap-6 text-stone-700">
      <span><span class="text-xl font-semibold"><%= @stats[:count] %></span> labels checked</span>
      <span><span class="text-xl font-semibold text-green-800"><%= @stats[:verdicts].values_at("pass", "pass_with_note").compact.sum %></span> passed</span>
      <span><span class="text-xl font-semibold text-red-800"><%= @stats[:verdicts]["fail"] || 0 %></span> failed</span>
      <span><span class="text-xl font-semibold text-amber-800"><%= @stats[:verdicts]["needs_review"] || 0 %></span> need review</span>
      <span>average <span class="text-xl font-semibold"><%= (@stats[:average_ms] / 1000.0).round(1) %>s</span></span>
      <span>95th percentile <span class="text-xl font-semibold"><%= (@stats[:p95_ms] / 1000.0).round(1) %>s</span></span>
    </div>
  </section>
<% end %>
