<div class="bg-white rounded-xl border border-stone-200 p-4">
  <h2 class="font-semibold mb-2">Where each element was found</h2>
  <p class="text-stone-600 mb-3">
    Hover a check to highlight it; click an outline for the reason. Boxes show
    where the tool read each value — they are not size or placement measurements.
  </p>

  <% if application.artwork.attached? && application.artwork.image? %>
    <div class="relative inline-block" data-bbox-overlay-target="frame">
      <%= image_tag url_for(application.artwork), class: "max-w-full rounded border border-stone-200",
            data: { bbox_overlay_target: "image" }, alt: "Label artwork for #{application.brand_name}" %>
    </div>
  <% elsif application.artwork.attached? && application.artwork.previewable? %>
    <div class="relative inline-block" data-bbox-overlay-target="frame">
      <%= image_tag url_for(application.artwork.preview(resize_to_limit: [ 800, 1100 ]).processed),
            class: "max-w-full rounded border border-stone-200",
            data: { bbox_overlay_target: "image" }, alt: "First page of the label artwork PDF" %>
      <p class="text-stone-500 mt-2">PDF — page 1 shown; outlines apply to page 1 only.</p>
    </div>
  <% elsif application.artwork.attached? %>
    <div class="rounded border border-stone-200 bg-stone-50 p-6 text-center text-stone-500">
      <p><%= application.artwork.filename %></p>
      <p class="mt-1">Preview unavailable in this environment.</p>
    </div>
  <% end %>
</div>
