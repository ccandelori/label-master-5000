<div class="bg-raised rounded-lg border border-line overflow-hidden">
  <div class="flex items-center justify-between gap-3 border-b border-line px-4 py-3">
    <div>
      <h2 class="font-semibold">Label artwork</h2>
      <p class="text-sm text-ink-faint">Inspect the label artwork alongside the findings.</p>
    </div>
    <% if local_assigns[:inspectable] %>
      <button type="button"
              data-action="inspector-dialog#open"
              class="rounded-lg border border-line-strong bg-raised px-3 py-1.5 text-sm font-medium hover:bg-panel cursor-pointer
                     focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus">
        Inspect
      </button>
    <% end %>
  </div>

  <div class="max-h-[72vh] overflow-auto bg-panel px-4 py-5 text-center">
    <%= render "label_applications/artwork_frames",
          application: application,
          image_class: "max-w-full rounded-sm border border-line bg-white shadow-sm shadow-ink/10" %>
  </div>
</div>
