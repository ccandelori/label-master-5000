<header id="validation_status_header" class="mb-5 border-b border-line pb-5">
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div class="min-w-0">
      <div class="mb-2 flex flex-wrap items-center gap-2">
        <% if attempt&.in_progress? %>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-warn-tint px-3 py-1 text-sm font-medium text-warn whitespace-nowrap">
            <span class="inline-block h-2 w-2 rounded-full bg-current animate-pulse" aria-hidden="true"></span>
            Running
          </span>
        <% elsif verification %>
          <%= verdict_chip(verification.overall_verdict) %>
        <% end %>
        <span class="rounded-full border border-line bg-panel px-2.5 py-1 text-xs font-medium text-ink-muted">
          <%= application.submitted? ? "Submitted" : "Validation" %>
        </span>
      </div>
      <h1 class="text-2xl font-semibold tracking-tight">
        <%= application.brand_name %>
      </h1>
      <p class="mt-1 text-ink-muted">
        <%= application.serial_number %> · <%= application.beverage_type.capitalize %> ·
        <%= application.imported? ? "Imported from #{application.country_of_origin}" : "Domestic" %>
        <% if application.alcohol_content %> · <%= application.alcohol_content %>% ABV<% end %>
        · <%= application.net_contents %>
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-2">
      <% if application.pre_review? %>
        <%= form_with url: label_application_check_path(application), method: :post,
              class: "flex items-center gap-2" do %>
          <label for="demo_model" class="sr-only">Refinement model for this validation</label>
          <%= select_tag :demo_model,
                demo_model_options_for(demo_model_value_for_verification(verification)),
                class: "rounded-lg border-line-strong text-sm" %>
          <%= submit_tag "Revalidate", class: "rounded-lg border border-line-strong bg-raised px-3 py-2 text-sm font-medium hover:bg-panel cursor-pointer" %>
        <% end %>
      <% end %>

      <%= link_to "Edit", edit_label_application_path(application),
            class: "rounded-lg border border-line-strong bg-raised px-4 py-2 text-sm font-medium hover:bg-panel" %>
    </div>
  </div>
</header>
