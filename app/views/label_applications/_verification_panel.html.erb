<% attempt ||= application.latest_verification_attempt %>

<div id="verification_panel">
  <% if attempt&.in_progress? %>
    <section class="bg-raised rounded-lg border border-warn/50 p-6" aria-live="polite">
      <div class="flex items-center gap-3">
        <span class="inline-block h-3 w-3 rounded-full bg-warn animate-pulse" aria-hidden="true"></span>
        <div>
          <p class="text-lg font-medium">Running validation.</p>
          <p class="text-ink-muted">
            <%= attempt.processing? ? "The verifier is processing this label." : "This label is queued for verification." %>
            Findings will update automatically when the run finishes.
          </p>
        </div>
      </div>
    </section>

  <% elsif verification.nil? %>
    <section class="bg-raised rounded-lg border border-line p-6 flex items-center gap-3" aria-live="polite">
      <span class="inline-block h-3 w-3 rounded-full bg-warn animate-pulse" aria-hidden="true"></span>
      <p class="text-lg">Running validation. Findings will appear here in a few seconds.</p>
    </section>

  <% elsif verification.error? %>
    <section class="bg-raised rounded-lg border border-fail/50 p-6">
      <div class="flex items-center gap-3 mb-2">
        <%= verdict_chip("error") %>
        <p class="text-lg font-medium">The analysis service could not process this label.</p>
      </div>
      <p class="text-ink-muted mb-4"><%= verification.error_message %></p>
      <%= button_to "Try again", label_application_path(verification.label_application), method: :patch,
            params: { label_application: { serial_number: verification.label_application.serial_number } },
            class: "rounded-lg bg-ink text-surface px-5 py-2 font-medium hover:opacity-90 cursor-pointer" %>
    </section>

  <% elsif verification.request_retake? %>
    <section class="bg-raised rounded-lg border border-warn/50 p-6">
      <div class="flex items-center gap-3 mb-2">
        <%= verdict_chip("request_retake") %>
        <p class="text-lg font-medium">The artwork could not be read reliably.</p>
      </div>
      <p class="text-ink-muted">
        Glare, blur, low resolution, or an extreme angle prevented a trustworthy
        reading. No field verdicts were issued. Ask for a better image rather
        than deciding from a bad read.
      </p>
      <% if application.reviewer_visible? || application.pre_review? %>
        <div class="mt-4">
          <%= render(application.reviewer_visible? ? "label_applications/decision_form" : "label_applications/pre_review_actions",
                application: application, verification: verification) %>
        </div>
      <% end %>
    </section>

  <% else %>
    <section class="space-y-5" data-controller="inspector-dialog">
      <% summary = verification.field_checks.group_by(&:verdict) %>
      <% problems = (summary["fail"] || []).size %>
      <% reviews = (summary["needs_review"] || []).size %>

      <div class="rounded-lg border bg-raised p-5 flex items-start gap-4
                  <%= verification.fail? ? "border-fail/50" : verification.needs_review? ? "border-warn/50" : "border-pass/50" %>">
        <%= verdict_chip(verification.overall_verdict) %>
        <div class="min-w-0 flex-1">
          <p class="text-lg font-medium">
            <% if verification.fail? %>
              Problems found: <%= pluralize(problems, "failed check") %><%= ", #{reviews} need your review" if reviews.positive? %>.
            <% elsif verification.needs_review? %>
              <%= pluralize(reviews, "check") %> need<%= "s" if reviews == 1 %> your judgment.
            <% else %>
              All checks passed<%= " with notes" if verification.pass_with_note? %>.
            <% end %>
          </p>
          <p class="mt-1 text-sm text-ink-muted">
            <% if application.reviewer_visible? %>
              Check the evidence, then record the decision.
            <% elsif application.pre_review? %>
              Validation result, fix or file from here.
            <% else %>
              Diagnostic record; hidden from history.
            <% end %>
          </p>
        </div>
        <div class="hidden sm:block text-right text-sm text-ink-faint whitespace-nowrap">
          <p>
            <%= "#{demo_model_label(verification.model_id)} · " if verification.model_id.present? %><%= verification.extraction_reused? ? "reading reused · " : "" %>checked in <%= ((verification.latency_ms || 0) / 1000.0).round(1) %>s
          </p>
          <% verification_timing_lines(verification, attempt).each do |line| %>
            <p class="mt-0.5"><%= line %></p>
          <% end %>
        </div>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-[minmax(360px,0.9fr)_minmax(440px,1.1fr)] gap-5">
        <div class="xl:sticky xl:top-5 self-start">
          <%= render "label_applications/artwork_panel",
                application: application,
                verification: verification,
                inspectable: true %>
        </div>

        <div class="bg-raised rounded-lg border border-line overflow-hidden">
          <div class="flex items-center justify-between gap-3 border-b border-line px-5 py-3">
            <div>
              <h2 class="font-semibold">Findings</h2>
              <p class="text-sm text-ink-faint">Application values compared against the label read.</p>
            </div>
          </div>
          <%= render "label_applications/findings_groups", application: application, verification: verification %>
          <div class="pb-2"></div>
        </div>
      </div>

      <% if application.reviewer_visible? || application.pre_review? %>
        <%= render(application.reviewer_visible? ? "label_applications/decision_form" : "label_applications/pre_review_actions",
              application: application, verification: verification) %>
      <% end %>

      <%= render "label_applications/inspector_dialog", application: application, verification: verification %>
    </section>
  <% end %>
</div>
