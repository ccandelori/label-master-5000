<% if verification.nil? %>
  <section class="bg-white rounded-xl border border-stone-200 p-6 flex items-center gap-3" aria-live="polite">
    <span class="inline-block h-3 w-3 rounded-full bg-amber-500 animate-pulse" aria-hidden="true"></span>
    <p class="text-lg">Checking this label now — results will appear here in a few seconds.</p>
  </section>

<% elsif verification.error? %>
  <section class="bg-white rounded-xl border border-red-200 p-6">
    <div class="flex items-center gap-3 mb-2">
      <%= verdict_chip("error") %>
      <p class="text-lg font-medium">The analysis service could not process this label.</p>
    </div>
    <p class="text-stone-600 mb-4"><%= verification.error_message %></p>
    <%= button_to "Try again", label_application_path(verification.label_application), method: :patch,
          params: { label_application: { serial_number: verification.label_application.serial_number } },
          class: "rounded-lg bg-stone-900 text-white px-5 py-2 font-medium hover:bg-stone-700 cursor-pointer" %>
  </section>

<% elsif verification.request_retake? %>
  <section class="bg-white rounded-xl border border-amber-200 p-6">
    <div class="flex items-center gap-3 mb-2">
      <%= verdict_chip("request_retake") %>
      <p class="text-lg font-medium">The artwork could not be read reliably.</p>
    </div>
    <p class="text-stone-600">
      Glare, blur, low resolution, or an extreme angle prevented a trustworthy
      reading. No field verdicts were issued — request a better image rather
      than judging from a bad read.
    </p>
    <div class="mt-4">
      <%= render(application.submitted? ? "label_applications/decision_form" : "label_applications/pre_review_actions",
            application: application, verification: verification) %>
    </div>
  </section>

<% else %>
  <section class="space-y-6">
    <% summary = verification.field_checks.group_by(&:verdict) %>
    <% problems = (summary["fail"] || []).size %>
    <% reviews = (summary["needs_review"] || []).size %>

    <div class="rounded-xl border p-5 flex items-start gap-3 bg-white
                <%= verification.fail? ? "border-red-300" : verification.needs_review? ? "border-amber-300" : "border-green-300" %>">
      <%= verdict_chip(verification.overall_verdict) %>
      <div class="flex-1">
        <p class="text-lg font-medium">
          <% if verification.fail? %>
            Problems found: <%= pluralize(problems, "failed check") %><%= ", #{reviews} need your review" if reviews.positive? %>.
          <% elsif verification.needs_review? %>
            <%= pluralize(reviews, "check") %> need<%= "s" if reviews == 1 %> your judgment.
          <% else %>
            All checks passed<%= " (with notes)" if verification.pass_with_note? %>.
          <% end %>
        </p>
        <p class="text-stone-600">
          <%= application.submitted? ? "The tool recommends — you decide." : "A pre-review check, not a TTB decision." %>
        </p>
      </div>
      <span class="text-stone-500 whitespace-nowrap">
        <%= verification.extraction_reused? ? "reading reused · " : "" %>checked in <%= ((verification.latency_ms || 0) / 1000.0).round(1) %>s
      </span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6"
         data-controller="bbox-overlay"
         data-bbox-overlay-boxes-value="<%= bbox_data(verification).to_json %>">
      <div class="lg:col-span-2">
        <%= render "label_applications/artwork_panel", application: application, verification: verification %>
      </div>

      <div class="lg:col-span-3 bg-white rounded-xl border border-stone-200 overflow-hidden">
        <table class="w-full text-left">
          <caption class="sr-only">Field-by-field verification results</caption>
          <thead>
            <tr class="border-b border-stone-200 text-stone-600">
              <th scope="col" class="px-4 py-3 font-medium">Check</th>
              <th scope="col" class="px-4 py-3 font-medium">Application</th>
              <th scope="col" class="px-4 py-3 font-medium">On the label</th>
              <th scope="col" class="px-4 py-3 font-medium">Result</th>
            </tr>
          </thead>
          <tbody>
            <% verification.field_checks.sort_by { |c| -c.severity }.each do |check| %>
              <tr class="border-t border-stone-100 align-top" data-field="<%= check.field %>"
                  data-action="mouseenter->bbox-overlay#highlight mouseleave->bbox-overlay#unhighlight">
                <th scope="row" class="px-4 py-3 font-medium"><%= field_label(check.field) %></th>
                <td class="px-4 py-3 text-stone-700"><%= check.expected.presence || "—" %></td>
                <td class="px-4 py-3 text-stone-700"><%= check.extracted.presence || "—" %></td>
                <td class="px-4 py-3"><%= verdict_chip(check.verdict) %></td>
              </tr>
              <% if check.note.present? || check.citation.present? %>
                <tr class="text-stone-600" data-field="<%= check.field %>">
                  <td colspan="4" class="px-4 pb-3 pt-0">
                    <% if check.note.present? %><span class="<%= check.verdict == 'fail' ? 'text-red-800' : '' %>"><%= check.note %></span><% end %>
                    <% if check.citation.present? %><span class="text-stone-500"> — <%= check.citation %></span><% end %>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <%= render(application.submitted? ? "label_applications/decision_form" : "label_applications/pre_review_actions",
          application: application, verification: verification) %>
  </section>
<% end %>
