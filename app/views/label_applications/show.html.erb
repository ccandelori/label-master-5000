<%= turbo_stream_from @application %>

<% display_verification = @verification_attempt&.in_progress? ? nil : @verification %>
<% history_scope = @application.verifications %>
<% history_scope = history_scope.where.not(id: display_verification.id) if display_verification %>
<% history = history_scope.order(created_at: :desc) %>

<% if @application.reviewer_visible? %>
  <nav class="mb-4 text-sm text-ink-muted" aria-label="Breadcrumb">
    <%= link_to "History", validation_history_path, class: "underline underline-offset-2 hover:text-ink" %>
    <span aria-hidden="true" class="mx-1 text-ink-faint">/</span>
    <span aria-current="page"><%= @application.serial_number %></span>
  </nav>
<% end %>

<%= render "validation_status_header", application: @application, verification: @verification, attempt: @verification_attempt %>

<main id="check_workspace" class="scroll-mt-5">
  <%= render "verification_panel", application: @application, verification: @verification, attempt: @verification_attempt %>
</main>

<section class="mt-8 grid grid-cols-1 lg:grid-cols-[minmax(0,0.9fr)_minmax(320px,0.6fr)] gap-5" aria-label="Application details">
  <div class="bg-raised rounded-lg border border-line p-5">
    <h2 class="font-semibold mb-3">Application record</h2>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3 text-sm">
      <div>
        <dt class="text-xs uppercase tracking-wide text-ink-faint">Applicant</dt>
        <dd class="mt-0.5"><%= @application.applicant_name_address %></dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-ink-faint">Class/type</dt>
        <dd class="mt-0.5"><%= @application.declared_class_type.presence || "Not stated" %></dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-ink-faint">Fanciful name</dt>
        <dd class="mt-0.5"><%= @application.fanciful_name.presence || "Not stated" %></dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-ink-faint">Varietals</dt>
        <dd class="mt-0.5"><%= @application.varietals.any? ? @application.varietals.join(", ") : "Not stated" %></dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-ink-faint">Appellation</dt>
        <dd class="mt-0.5"><%= @application.appellation.presence || "Not stated" %></dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-ink-faint">Vintage</dt>
        <dd class="mt-0.5"><%= @application.vintage_year.presence || "Not stated" %></dd>
      </div>
    </dl>
  </div>

  <% if history.any? %>
    <div class="bg-raised rounded-lg border border-line overflow-hidden">
      <div class="border-b border-line px-5 py-3">
        <h2 class="font-semibold">Earlier checks</h2>
      </div>
      <ul class="divide-y divide-line/60">
        <% history.each do |verification| %>
          <li class="px-5 py-3">
            <div class="flex items-center justify-between gap-3">
              <span class="text-sm text-ink-muted"><%= verification.created_at.strftime("%b %-d, %H:%M:%S") %></span>
              <%= verdict_chip(verification.overall_verdict) %>
            </div>
            <p class="mt-1 text-sm text-ink-faint">
              <%= demo_model_label(verification.model_id) if verification.model_id.present? %>
              <%= " · reading reused" if verification.extraction_reused %>
              <%= " · Decision: #{verification.decision.humanize}" if verification.decision %>
            </p>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</section>
