<%= turbo_stream_from @application %>

<%# Pre-review applications are the applicant's sandbox; only submitted
    work breadcrumbs back into the reviewer queue. %>
<% if @application.submitted? %>
  <nav class="mb-3 text-base text-ink-muted" aria-label="Breadcrumb">
    <%= link_to "Review queue", reviewer_queue_path, class: "underline underline-offset-2 hover:text-ink" %>
    <span aria-hidden="true" class="mx-1 text-ink-faint">/</span>
    <span aria-current="page"><%= @application.serial_number %></span>
  </nav>
<% end %>

<div class="flex items-start justify-between flex-wrap gap-3 mb-6">
  <div>
    <h1 class="text-2xl font-semibold">
      Application <%= @application.serial_number %> — <%= @application.brand_name %>
    </h1>
    <p class="text-ink-muted mt-1">
      <%= @application.beverage_type.capitalize %> ·
      <%= @application.imported? ? "Imported (#{@application.country_of_origin})" : "Domestic" %>
      <% if @application.alcohol_content %> · <%= @application.alcohol_content %>% ABV<% end %>
      · <%= @application.net_contents %>
    </p>
  </div>
  <%= link_to "Edit and re-check", edit_label_application_path(@application),
        class: "rounded-lg border border-line-strong bg-raised px-4 py-2 font-medium hover:bg-panel" %>
</div>

<div id="verification_panel">
  <%= render "verification_panel", application: @application, verification: @verification %>
</div>

<% history = @application.verifications.order(created_at: :desc).offset(1) %>
<% if history.any? %>
  <section class="mt-8" aria-label="Verification history">
    <h2 class="text-lg font-semibold mb-3">Earlier checks of this application</h2>
    <ul class="space-y-2">
      <% history.each do |verification| %>
        <li class="bg-raised rounded-lg border border-line px-4 py-3 flex items-center justify-between flex-wrap gap-2">
          <span class="text-ink-muted"><%= verification.created_at.strftime("%b %-d, %H:%M:%S") %></span>
          <%= verdict_chip(verification.overall_verdict) %>
          <% if verification.decision %>
            <span class="text-ink-muted">Decision: <%= verification.decision.humanize %></span>
          <% end %>
          <% if verification.extraction_reused %>
            <span class="text-ink-faint">reading reused</span>
          <% end %>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>
