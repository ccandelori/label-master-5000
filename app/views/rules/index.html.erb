<% content_for :title, "Rules reference" %>

<div class="mb-6">
  <h1 class="text-2xl font-semibold">Rules reference</h1>
  <p class="text-stone-600 mt-1 max-w-2xl">
    The rule set every check runs against, loaded from the TTB Beverage
    Alcohol Manuals. The BAMs are this tool's source of truth; where current
    regulations have moved on, findings carry a note citing both.
  </p>
</div>

<section class="bg-white rounded-xl border border-stone-200 p-6 mb-6" aria-labelledby="health-warning-heading">
  <h2 id="health-warning-heading" class="text-lg font-semibold mb-2">Health warning statement</h2>
  <p class="text-stone-600 mb-3">
    Required verbatim on every container at or above 0.5% alcohol by volume —
    <%= @shared.dig("health_warning", "citation") %>.
  </p>
  <blockquote class="rounded-lg bg-stone-50 border border-stone-200 px-4 py-3 text-stone-800">
    <%= Rules::Data.statutory_warning_text %>
  </blockquote>
</section>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  <% @commodities.each do |name, rules| %>
    <section class="bg-white rounded-xl border border-stone-200 p-6" aria-labelledby="commodity-<%= name %>">
      <h2 id="commodity-<%= name %>" class="text-lg font-semibold mb-3"><%= name == "malt" ? "Malt beverages" : name.capitalize %></h2>
      <dl class="space-y-3 text-stone-700">
        <div>
          <dt class="font-medium text-stone-900">Net contents</dt>
          <dd>
            <%= rules.dig("net_contents", "required_system") == "metric" ? "Metric standards of fill" : "American measure" %>
            — <%= rules.dig("net_contents", "citation") %>
          </dd>
        </div>
        <div>
          <dt class="font-medium text-stone-900">Alcohol content</dt>
          <dd><%= rules.dig("alcohol_content", "citation") %></dd>
        </div>
        <div>
          <dt class="font-medium text-stone-900">Class and type designations</dt>
          <dd><%= pluralize(rules.dig("designations", "entries").size, "recognized designation") %> — <%= rules.dig("designations", "citation") %></dd>
        </div>
        <div>
          <dt class="font-medium text-stone-900">Conditional disclosures</dt>
          <dd><%= pluralize(rules["disclosures"].size, "disclosure rule") %></dd>
        </div>
      </dl>
    </section>
  <% end %>
</div>
