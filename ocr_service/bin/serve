#!/usr/bin/env bash
# Runs the OCR sidecar. OCR_PORT must match the Rails app's
# EXTRACTION_PADDLE_URL (default http://127.0.0.1:8765).
set -euo pipefail
cd "$(dirname "$0")/.."
stop_requested=0

trap 'stop_requested=1' INT TERM

if [ ! -x .venv/bin/uvicorn ]; then
  echo "ocr_service: no virtualenv - run ocr_service/bin/setup"
  exit 78
fi

# PaddleOCR's CPU memory arena grows with the largest images it has seen
# and never shrinks. Set OCR_MAX_READS to recycle the worker after a
# bounded number of reads; by default the worker stays up so ordinary
# batches do not hit a reload window mid-verification.
while true; do
  set +e
  .venv/bin/uvicorn app:app --host 127.0.0.1 --port "${OCR_PORT:-8765}"
  status=$?
  set -e
  if [ "$stop_requested" -eq 1 ]; then
    echo "ocr_service: stop requested, exiting"
    exit "$status"
  fi
  echo "ocr_service: worker exited with status ${status} after ${OCR_MAX_READS:-0} reads, restarting"
done
